# =============================================================================
# OXY AI — Environment Variables Template
# Copy this file to .env and fill in your real values.
# NEVER commit the .env file to version control.
# =============================================================================

# Gemini API Key (primary — used first for every request)
GEMINI_API_KEY=your_gemini_api_key_here

# Database Configuration
DATABASE_URL="postgres://username:password@localhost:5432/oxiai"

# Authentication Configuration
JWT_SECRET="your-super-secret-jwt-key"

# Tavily API Configuration
TAVILY_API_KEY="your-tavily-api-key-here"

# Gemini API Key 2 (fallback — optional but recommended)
GEMINI_API_KEY_2=your_gemini_api_key_2_here

# Gemini API Key 3 (fallback — optional)
GEMINI_API_KEY_3=your_gemini_api_key_3_here

# Gemini API Key 4 (fallback — optional)
GEMINI_API_KEY_4=your_gemini_api_key_4_here

# Gemini API Key 5 (fallback — optional)
GEMINI_API_KEY_5=your_gemini_api_key_5_here

# Server port (matches the value in .env)
PORT=3002
