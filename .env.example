# =============================================================================
# OXY AI — Environment Variables Template
# Copy this file to .env and fill in your real values.
# NEVER commit the .env file to version control.
# =============================================================================

# Gemini API Key (primary — used first for every request)
GEMINI_API_KEY=your_gemini_api_key_here

# Database Configuration
DATABASE_URL="postgres://username:password@localhost:5432/oxiai"

# Cloudflare Workers AI (for image generation/editing)
# Get these from Cloudflare Dashboard → Workers & Pages → Workers AI
# Generation: flux-1-schnell / SDXL-Lightning / Dreamshaper-8-LCM (auto fallback)
# Editing:    SD-v1.5-img2img — free tier (10k requests/day)
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here

# Supabase Storage (for storing generated/edited images)
# Get these from Supabase Dashboard → Project Settings → API
# SUPABASE_URL = Project URL (e.g. https://xxxxx.supabase.co)
# SUPABASE_SERVICE_ROLE_KEY = service_role key (or new "Secret key" format starting with sb_secret_)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your_key_here

# Authentication Configuration
JWT_SECRET="your-super-secret-jwt-key"

# Tavily API Configuration
TAVILY_API_KEY="your-tavily-api-key-here"

# Gemini API Key 2 (fallback — optional but recommended)
GEMINI_API_KEY_2=your_gemini_api_key_2_here

# Gemini API Key 3 (fallback — optional)
GEMINI_API_KEY_3=your_gemini_api_key_3_here

# Gemini API Key 4 (fallback — optional)
GEMINI_API_KEY_4=your_gemini_api_key_4_here

# Gemini API Key 5 (fallback — optional)
GEMINI_API_KEY_5=your_gemini_api_key_5_here

# Server port (matches the value in .env)
PORT=3002

# Firebase Admin SDK (required on Vercel for token verification)
# Get these from Firebase Console > Project Settings > Service Accounts >
# "Generate new private key". The JSON file contains client_email and private_key.
# On Vercel, set these in the dashboard Environment Variables section.
# Locally, you can also set GOOGLE_APPLICATION_CREDENTIALS=path/to/key.json instead.
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@vosil-ai.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# FIREBASE_PROJECT_ID=vosil-ai
